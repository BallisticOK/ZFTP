<ui:FluentWindow x:Class="ZFTP.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ZFTP.App"
        Title="ZFTP" Height="620" Width="1040"
        MinHeight="520" MinWidth="900"
        Icon="/Assets/logo.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ZFTP — SFTP Drive Manager">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/logo.png" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <TabControl Grid.Row="1" Margin="8,4,8,4" Background="Transparent" BorderThickness="0">

            <!-- ====================== DRIVES TAB ====================== -->
            <TabItem Header="Drives">
                <Grid Margin="6,12,6,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:Button Content="Mount all" Appearance="Primary"
                                   Icon="{ui:SymbolIcon Play24}" Click="MountAll_Click" />
                        <ui:Button Content="Unmount all" Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Stop24}" Click="UnmountAll_Click" />
                        <ui:Button Content="Save" Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Save24}" Click="Save_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="2,0,0,8" Opacity="0.75"
                               Text="Add, edit, enable and mount your SFTP drives. Each drive appears in Explorer under the name you give it." />

                    <!-- grid + side buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="10" Background="#14FFFFFF"
                                BorderBrush="#1FFFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- column header (kept aligned with the rows below) -->
                                <Grid Grid.Row="0" Margin="22,12,20,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="1.4*" />
                                        <ColumnDefinition Width="1.7*" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="104" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="NAME" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                                    <TextBlock Grid.Column="2" Text="DRIVE" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                                    <TextBlock Grid.Column="3" Text="REMOTE HOST" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                                    <TextBlock Grid.Column="4" Text="REMOTE DIRECTORY" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                                    <TextBlock Grid.Column="5" Text="ON" FontSize="11" FontWeight="SemiBold" Opacity="0.55" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="6" Text="STATUS" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                                </Grid>
                                <Border Grid.Row="1" Height="1" Background="#18FFFFFF" Margin="14,0" />

                                <ListBox x:Name="DrivesList" Grid.Row="2"
                                         Background="Transparent" BorderThickness="0" Padding="6,6"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MouseDoubleClick="DrivesGrid_MouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="6,2" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent" Padding="10,0">
                                                            <Grid>
                                                                <Border x:Name="Accent" Width="3" HorizontalAlignment="Left"
                                                                        CornerRadius="2" Margin="-6,8" Background="Transparent" />
                                                                <ContentPresenter VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#1EFFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#382D7DD2" />
                                                                <Setter TargetName="Accent" Property="Background" Value="#5BA8F0" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="48">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="1.3*" />
                                                    <ColumnDefinition Width="66" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1.7*" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="104" />
                                                </Grid.ColumnDefinitions>

                                                <ui:SymbolIcon Grid.Column="0" Symbol="CloudLink24" FontSize="18"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding TagBrush}" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="14" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ProviderLabel}" FontSize="11"
                                                               Opacity="0.6" />
                                                </StackPanel>

                                                <Border Grid.Column="2" Background="#2A6CB0FF" CornerRadius="5"
                                                        Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DriveLabel}" FontWeight="SemiBold" FontSize="12" />
                                                </Border>

                                                <TextBlock Grid.Column="3" Text="{Binding Host}" VerticalAlignment="Center"
                                                           Opacity="0.85" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="4" Text="{Binding RemoteRoot}" VerticalAlignment="Center"
                                                           Opacity="0.85" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />

                                                <CheckBox Grid.Column="5" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />

                                                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="9" Height="9" Fill="{Binding StatusColor}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" MinWidth="120">
                            <ui:Button Content="New" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                       Icon="{ui:SymbolIcon Add24}" Click="New_Click" />
                            <ui:Button Content="Edit" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                       Icon="{ui:SymbolIcon Edit24}" Click="Edit_Click" />
                            <ui:Button Content="Duplicate" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                       Icon="{ui:SymbolIcon Copy24}" Click="Duplicate_Click" />
                            <ui:Button Content="Delete" HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                       Icon="{ui:SymbolIcon Delete24}" Click="Delete_Click" />
                            <ui:Button Content="Connect" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                       Appearance="Primary" Icon="{ui:SymbolIcon PlugConnected24}" Click="Connect_Click" />
                            <ui:Button Content="Disconnect" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                       Icon="{ui:SymbolIcon PlugDisconnected24}" Click="Disconnect_Click" />
                            <ui:Button Content="Open" HorizontalAlignment="Stretch"
                                       Icon="{ui:SymbolIcon FolderOpen24}" Click="Open_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ====================== SETTINGS TAB ====================== -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,20,20,16" MaxWidth="680" HorizontalAlignment="Left">

                        <TextBlock Text="Startup &amp; tray" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Start ZFTP with Windows" FontWeight="SemiBold" />
                                    <TextBlock Text="Launch automatically when you log into Windows."
                                               Opacity="0.7" FontSize="12" />
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="StartWithWindowsToggle" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center" Click="StartWithWindows_Toggled" />
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Start in the system tray" FontWeight="SemiBold" />
                                    <TextBlock Text="Open hidden in the tray instead of showing the window."
                                               Opacity="0.7" FontSize="12" />
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="StartMinimizedToggle" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center" Click="StartMinimized_Toggled" />
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Keep running in tray when window is closed" FontWeight="SemiBold" />
                                    <TextBlock Text="Closing the window hides it to the tray (drives stay mounted). Turn off to fully quit on close."
                                               Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="TrayOnCloseToggle" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center" Click="TrayOnClose_Toggled" />
                            </Grid>
                        </ui:Card>

                        <TextBlock Text="Mounting" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,12" />

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Auto-mount drives on startup" FontWeight="SemiBold" />
                                    <TextBlock Text="When ZFTP starts, mount every enabled drive that has Auto-mount turned on (set per drive in its Edit dialog)."
                                               Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="AutoMountToggle" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center" Click="AutoMountOnStart_Toggled" />
                            </Grid>
                        </ui:Card>

                        <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,12" />

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Theme" FontWeight="SemiBold" />
                                    <TextBlock Text="Switch between the dark and light look." Opacity="0.7" FontSize="12" />
                                </StackPanel>
                                <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          MinWidth="170" SelectionChanged="Theme_Changed" />
                                <!-- Items are populated in code from the theme list. -->
                            </Grid>
                        </ui:Card>

                        <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,12" />

                        <ui:Card Margin="0,0,0,10" Padding="16,14">
                            <Grid VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="VersionText" Text="ZFTP version 0.1.0" FontWeight="SemiBold" />
                                    <TextBlock x:Name="UpdateStatusText" Text="Check for a newer version of ZFTP."
                                               Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                                <ui:Button x:Name="CheckUpdateButton" Content="Check for updates"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Icon="{ui:SymbolIcon ArrowSync24}" Click="CheckUpdate_Click" />
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,8,0,0" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Config location" FontWeight="SemiBold" Margin="0,0,0,2" />
                                <TextBlock x:Name="ConfigPathText" Opacity="0.6" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ====================== STATUS BAR ====================== -->
        <Border Grid.Row="2" Background="#22000000" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="GlobalStatusDot" Width="9" Height="9" Fill="Gray"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="GlobalStatusText" Text="Idle — no drives mounted" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Foreground="#4FC3F7"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock x:Name="DownSpeedText" Text="0 B/s" VerticalAlignment="Center" MinWidth="62" />
                    <TextBlock x:Name="DownTotalText" Text="(0 B)" Opacity="0.55" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14" Foreground="#81C784"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock x:Name="UpSpeedText" Text="0 B/s" VerticalAlignment="Center" MinWidth="62" />
                    <TextBlock x:Name="UpTotalText" Text="(0 B)" Opacity="0.55" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,0" />
                </StackPanel>

                <TextBlock Grid.Column="3" x:Name="FooterVersionText" Text="ZFTP" Opacity="0.55" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
