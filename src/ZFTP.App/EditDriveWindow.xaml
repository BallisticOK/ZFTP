<ui:FluentWindow x:Class="ZFTP.App.EditDriveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Edit drive" Height="700" Width="540"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Drive settings" ShowMaximize="False" ShowMinimize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,8,22,8">
            <StackPanel>
                <TextBlock Text="Type" Margin="0,0,0,4" />
                <ComboBox x:Name="TypeCombo" Margin="0,0,0,14" SelectionChanged="TypeCombo_SelectionChanged">
                    <ComboBoxItem Content="SFTP" />
                    <ComboBoxItem Content="FTP" />
                    <ComboBoxItem Content="FTP over TLS (FTPS)" />
                    <ComboBoxItem Content="WebDAV" />
                    <ComboBoxItem Content="Amazon S3 / compatible" />
                    <ComboBoxItem Content="Google Drive" />
                    <ComboBoxItem Content="Dropbox" />
                    <ComboBoxItem Content="OneDrive" />
                    <ComboBoxItem Content="Box" />
                </ComboBox>

                <TextBlock Text="Display name" Margin="0,0,0,4" />
                <ui:TextBox x:Name="NameBox" PlaceholderText="My Server" Margin="0,0,0,14" />

                <!-- Host + Port (SFTP / FTP / FTPS) -->
                <StackPanel x:Name="HostPanel">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Host" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="HostBox" PlaceholderText="Host IP" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Port" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PortBox" Text="22" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- WebDAV URL -->
                <StackPanel x:Name="UrlPanel" Visibility="Collapsed">
                    <TextBlock Text="Server URL" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="UrlBox" PlaceholderText="https://dav.example.com/remote.php/webdav" Margin="0,0,0,14" />
                </StackPanel>

                <!-- Username (SFTP/FTP/FTPS/WebDAV) -->
                <StackPanel x:Name="UserPanel">
                    <TextBlock Text="Username" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="UserBox" PlaceholderText="Username" Margin="0,0,0,14" />
                </StackPanel>

                <!-- Auth method (SFTP only) -->
                <StackPanel x:Name="AuthPanel">
                    <TextBlock Text="Authentication" Margin="0,0,0,4" />
                    <ComboBox x:Name="AuthCombo" Margin="0,0,0,14" SelectionChanged="AuthCombo_SelectionChanged">
                        <ComboBoxItem Content="Password" IsSelected="True" />
                        <ComboBoxItem Content="SSH private key" />
                    </ComboBox>
                    <CheckBox x:Name="ForgetHostKeyCheck" Margin="0,0,0,14"
                              Content="Forget saved server key (re-trust on next connect)" />
                </StackPanel>

                <!-- Password (SFTP/FTP/FTPS/WebDAV) -->
                <StackPanel x:Name="PasswordPanel">
                    <TextBlock Text="Password" Margin="0,0,0,4" />
                    <ui:PasswordBox x:Name="PasswordBox" Margin="0,0,0,14" />
                </StackPanel>

                <!-- SSH key (SFTP only) -->
                <StackPanel x:Name="KeyPanel" Visibility="Collapsed">
                    <TextBlock Text="Private key file" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="KeyPathBox" Grid.Column="0" PlaceholderText="C:\Users\you\.ssh\id_rsa" />
                        <ui:Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="Browse_Click" />
                    </Grid>
                    <TextBlock Text="Key passphrase (if any)" Margin="0,0,0,4" />
                    <ui:PasswordBox x:Name="KeyPassBox" Margin="0,0,0,14" />
                </StackPanel>

                <!-- S3 -->
                <StackPanel x:Name="S3Panel" Visibility="Collapsed">
                    <TextBlock Text="Access Key ID" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="S3KeyBox" Margin="0,0,0,14" />
                    <TextBlock Text="Secret Access Key" Margin="0,0,0,4" />
                    <ui:PasswordBox x:Name="S3SecretBox" Margin="0,0,0,14" />
                    <TextBlock Text="Bucket" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="S3BucketBox" Margin="0,0,0,14" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Region (optional)" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="S3RegionBox" PlaceholderText="us-east-1" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Endpoint (blank = AWS)" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="S3EndpointBox" PlaceholderText="s3.wasabisys.com" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- OAuth cloud drives -->
                <StackPanel x:Name="OAuthPanel" Visibility="Collapsed">
                    <ui:Card Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="OAuthStatusText" Text="Not signed in." FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Click below — your browser opens so you can sign into your account. ZFTP never sees your password. You only do this once; it's remembered."
                                       Opacity="0.7" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10" />
                            <ui:Button x:Name="SignInButton" Content="Sign in with browser"
                                       Icon="{ui:SymbolIcon Globe24}" Click="SignIn_Click" />
                        </StackPanel>
                    </ui:Card>

                    <Expander Header="Advanced — own app credentials (optional)" Margin="0,0,0,14">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12" Margin="0,0,0,10"
                                       Text="Leave blank to use the built-in sign-in. If the cloud keeps asking you to log back in, paste your own free Client ID &amp; Secret here for a permanent connection (see the provider's developer console)." />
                            <TextBlock Text="Client ID" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="ClientIdBox" Margin="0,0,0,10" />
                            <TextBlock Text="Client Secret" Margin="0,0,0,4" />
                            <ui:PasswordBox x:Name="ClientSecretBox" />
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <!-- Remote folder + drive -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Remote folder" Margin="0,0,0,4" />
                        <ui:TextBox x:Name="RootBox" PlaceholderText="/  (root)" Text="/" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Drive" Margin="0,0,0,4" />
                        <ComboBox x:Name="DriveCombo" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Permissions" Margin="0,0,0,4" />
                        <ComboBox x:Name="AccessCombo">
                            <ComboBoxItem Content="Read &amp; Write" IsSelected="True" />
                            <ComboBoxItem Content="Read only" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Colour" Margin="0,0,0,4" />
                        <ComboBox x:Name="ColorCombo" />
                    </StackPanel>
                </Grid>

                <ui:Card Padding="12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Enabled" FontWeight="SemiBold" />
                                <TextBlock Text="Include this drive in Mount all." Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="EnabledToggle" HorizontalAlignment="Right" IsChecked="True" />
                        </Grid>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Auto-mount on startup" FontWeight="SemiBold" />
                                <TextBlock Text="Mount this drive automatically when ZFTP starts." Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="AutoMountToggle" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="22,10,22,16">
            <ui:Button Content="Cancel" MinWidth="90" Click="Cancel_Click" />
            <ui:Button Content="Save" Appearance="Primary" MinWidth="90" Margin="10,0,0,0" Click="Save_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
